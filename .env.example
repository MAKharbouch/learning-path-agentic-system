# LLM — any langchain-supported provider (openai, google_genai, ollama, anthropic, etc.)
LLM_PROVIDER=google_genai
LLM_MODEL=gemini-2.0-flash

# Embeddings — "openai" or "local" (switching requires re-running scripts/embed_courses.py)
EMBEDDING_PROVIDER=local

# API keys — only the one matching your provider is needed
OPENAI_API_KEY=
GOOGLE_API_KEY=